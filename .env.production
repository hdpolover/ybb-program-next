# Production Environment
# API Configuration where backend (ybb-platform) is hosted
NEXT_PUBLIC_API_URL=https://api.ybbhub.com/v1

# S3 Storage Configuration
NEXT_PUBLIC_S3_URL=https://s3.ybbhub.com

# Site Configuration
NEXT_PUBLIC_SITE_URL=https://youthacademicforum.com

# Domains Configuration (Traefik Rule)
# Format: Host(`domain1.com`) || Host(`domain2.com`)
APP_DOMAINS_RULE=Host(`youthacademicforum.com`) || Host(`istanbulyouthsummit.com`) || Host(`test.japanyouthsummit.com`)
