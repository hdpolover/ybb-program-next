# Development Environment Example
# API Configuration where backend (ybb-platform) is hosted
NEXT_PUBLIC_API_URL=http://localhost:4000/v1

# S3 Storage Configuration
# Point to DigitalOcean Spaces bucket (Dev/Staging Shared)
# Format: https://<endpoint>/<bucket> (Path style) or https://<bucket>.<endpoint>
NEXT_PUBLIC_S3_URL=https://cdn.ybbhub.com

# Site Configuration
NEXT_PUBLIC_SITE_URL=http://localhost:3010

