# Production Environment Example
# API Configuration where backend (ybb-platform) is hosted
NEXT_PUBLIC_API_URL=https://api.example.com/v1

# Internal URL for server-side self-fetches (Next.js route → Next.js route).
# Must be localhost so the container can reach itself without going through the public domain.
# Default is http://localhost:3000 if not set.
NEXT_INTERNAL_URL=http://localhost:3000

# S3 Storage Configuration
# DigitalOcean Spaces Production Bucket
NEXT_PUBLIC_S3_URL=https://cdn.ybbhub.com

# Optional runtime fallback so container environment matches the built version.
# Keep this the same value as APP_BUILD_ID for each deployment.
# NEXT_PUBLIC_APP_BUILD_ID is generated automatically from APP_BUILD_ID during build.
# Or CDN: https://cdn.ybbhub.com

# Site Configuration (Fallback/Default)
# Used only when dynamic host detection fails
NEXT_PUBLIC_SITE_URL=https://www.example.com

# Web app build/version identifier used for hard-refresh detection after deploys
# Set this to your release tag, commit SHA, or CI build number.
APP_BUILD_ID=release-20260317-001

# Domains Configuration (Traefik Rule)
# Format: Host(`domain1.com`) || Host(`domain2.com`)
APP_DOMAINS_RULE=Host(`youthacademicforum.com`) || Host(`istanbulyouthsummit.com`)
