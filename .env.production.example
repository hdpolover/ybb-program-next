# Production Environment Example
# API Configuration where backend (ybb-platform) is hosted
NEXT_PUBLIC_API_URL=https://api.example.com/v1

# S3 Storage Configuration
# DigitalOcean Spaces Production Bucket
NEXT_PUBLIC_S3_URL=https://cdn.ybbhub.com
# Or CDN: https://cdn.ybbhub.com

# Site Configuration (Fallback/Default)
# Used only when dynamic host detection fails
NEXT_PUBLIC_SITE_URL=https://www.example.com

# Domains Configuration (Traefik Rule)
# Format: Host(`domain1.com`) || Host(`domain2.com`)
APP_DOMAINS_RULE=Host(`youthacademicforum.com`) || Host(`istanbulyouthsummit.com`)
